{
  "name": "lslinterpreter",
  "version": "0.1.0",
  "private": true,
  "description": "Static analyzer, memory estimator, and (eventually) interpreter for Linden Scripting Language.",
  "type": "module",
  "bin": {
    "lsl-ide": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsx src/cli.ts",
    "cli": "tsx src/cli.ts",
    "build:builtins": "tsx scripts/build-builtins.ts"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.5"
  }
}
